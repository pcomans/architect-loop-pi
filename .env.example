# Builder (required) — DeepSeek by default; see skills/architect/dispatch.md to switch providers
DEEPSEEK_API_KEY=
# Web search (optional) — set for Tavily, else web_search falls back to keyless DuckDuckGo
TAVILY_API_KEY=
# Optional model overrides (defaults shown)
ARCHITECT_BUILDER_MODEL=deepseek/deepseek-v4-pro
ARCHITECT_RESEARCH_MODEL=deepseek/deepseek-v4-flash
